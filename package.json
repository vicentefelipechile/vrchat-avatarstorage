{
	"name": "vrchat-avatarstorage",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"deploy": "node src/tools/build-frontend.mjs && wrangler deploy",
		"deploy:test": "node src/tools/build-frontend.mjs && wrangler versions upload",
		"dev": "concurrently --kill-others --names \"esbuild,wrangler\" --prefix-colors \"cyan,yellow\" --delay \"0,3000\" \"node src/tools/build-frontend.mjs --watch --dev\" \"wrangler dev\"",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"seed": "tsx src/test/setup/populate.ts",
		"build-frontend": "node src/tools/build-frontend.mjs",
		"build-frontend:dev": "node src/tools/build-frontend.mjs --dev",
		"build-frontend:watch": "node src/tools/build-frontend.mjs --watch --dev",
		"i18n-manager": "node src/tools/i18n-manager.mjs"
	},
	"devDependencies": {
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.5.0",
		"@types/qrcode": "^1.5.6",
		"concurrently": "^9.2.1",
		"esbuild": "^0.27.4",
		"typescript": "^5.9.3",
		"vitest": "^3.2",
		"wrangler": "^4.73.0"
	},
	"dependencies": {
		"@hapi/iron": "7.0.1",
		"bcryptjs": "3.0.3",
		"dompurify": "^3.4.0",
		"hono": "4.12.12",
		"lucide": "1.7.0",
		"marked": "^17.0.5",
		"otpauth": "9.5.0",
		"qrcode": "1.5.4",
		"tsx": "4.21.0",
		"zod": "4.3.6"
	}
}
