{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "vrcstorage-cdn",
	"main": "src/cdn-worker.ts",
	"compatibility_date": "2026-02-12",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true,
	},
	"r2_buckets": [
		{
			"bucket_name": "vrcstorage-media",
			"binding": "MEDIA_BUCKET",
			"remote": false
		},
	],
	// Production: add custom domain cdn.vrcstorage.lat via Cloudflare dashboard
	// Workers & Pages → vrcstorage-cdn → Settings → Triggers → Custom Domains
}